# === Sairen Workflow System ===

# Serveur
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug

# PostgreSQL
DATABASE_URL=postgresql://sairen:sairen_dev@localhost:5432/sairen_workflow?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-in-production-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# BullMQ
BULL_BOARD_PORT=3001
WORKER_CONCURRENCY=10

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid (Email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@sairen.fr

# WhatsApp Business
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Mode sandbox (désactive les envois réels)
SANDBOX_MODE=true
